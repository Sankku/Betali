{
  "name": "agropanel-backend",
  "version": "1.0.0",
  "description": "AgroPanel Backend API - Stock management system with SENASA integration",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "bun --watch run server.js",
    "test": "jest",
    "test:container": "node scripts/test-container.js",
    "test:endpoints": "node scripts/test-endpoints.js",
    "test:api": "node scripts/test-api.js",
    "test:api:auth": "node scripts/test-api.js --token=$TEST_JWT_TOKEN",
    "test:quick": "bash scripts/quick-test.sh",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "format": "prettier --write .",
    "health": "curl -f http://localhost:4000/health || exit 1",
    "db:test": "node scripts/test-connection.js",
    "db:migrate": "node scripts/migrate.js",
    "db:seed": "node scripts/seed.js",
    "docs": "node scripts/generate-docs.js",
    "clean": "rm -rf node_modules package-lock.json && npm install"
  },
  "keywords": [
    "agriculture",
    "stock-management",
    "senasa",
    "inventory",
    "nodejs",
    "express",
    "supabase"
  ],
  "author": "AgroPanel Team",
  "license": "MIT",
  "dependencies": {
    "@supabase/supabase-js": "^2.39.7",
    "axios": "^1.8.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "mercadopago": "^2.3.0",
    "node-fetch": "^2.7.0",
    "pg": "^8.14.0",
    "supabase": "^2.19.7",
    "uuid": "^9.0.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-node": "^11.1.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.1",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/agropanel.git"
  },
  "bugs": {
    "url": "https://github.com/your-org/agropanel/issues"
  },
  "homepage": "https://github.com/your-org/agropanel#readme"
}