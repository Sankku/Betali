{
  "name": "betali-backend",
  "version": "1.0.0",
  "description": "Betali Backend API - Business inventory management SaaS platform",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "bun --watch run server.js",
    "test": "jest",
    "test:container": "node scripts/test-container.js",
    "test:endpoints": "node scripts/test-endpoints.js",
    "test:api": "node scripts/test-api.js",
    "test:api:auth": "node scripts/test-api.js --token=$TEST_JWT_TOKEN",
    "test:quick": "bash scripts/quick-test.sh",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "format": "prettier --write .",
    "health": "curl -f http://localhost:4000/health || exit 1",
    "db:test": "node scripts/test-connection.js",
    "db:migrate": "node scripts/migrate.js",
    "db:seed": "node scripts/seed.js",
    "docs": "node scripts/generate-docs.js",
    "clean": "rm -rf node_modules package-lock.json && npm install"
  },
  "keywords": [
    "business",
    "inventory-management",
    "saas",
    "multi-tenant",
    "nodejs",
    "express",
    "supabase"
  ],
  "author": "Betali Team",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.3",
    "@supabase/supabase-js": "^2.39.7",
    "axios": "^1.8.3",
    "bcryptjs": "^3.0.2",
    "body-parser": "^2.2.2",
    "brace-expansion": "^4.0.1",
    "cors": "^2.8.5",
    "diff": "^8.0.3",
    "dompurify": "^3.2.6",
    "dotenv": "^16.4.7",
    "esbuild": "^0.27.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.0.1",
    "express-slow-down": "^2.1.0",
    "file-type": "^21.0.0",
    "helmet": "^8.1.0",
    "i18next": "^25.3.2",
    "i18next-fs-backend": "^2.6.0",
    "joi": "^17.13.3",
    "js-yaml": "^4.1.1",
    "jsdom": "^26.1.0",
    "mercadopago": "^2.3.0",
    "mime-types": "^3.0.1",
    "multer": "^2.0.2",
    "node-fetch": "^2.7.0",
    "pg": "^8.14.0",
    "qs": "^6.14.1",
    "react-router": "^7.12.0",
    "react-router-dom": "^7.12.0",
    "supabase": "^2.19.7",
    "uuid": "^9.0.1",
    "validator": "^13.15.26",
    "vite": "^7.3.1",
    "winston": "^3.11.0",
    "xss": "^1.0.15"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-node": "^11.1.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.1",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/betali.git"
  },
  "bugs": {
    "url": "https://github.com/your-org/betali/issues"
  },
  "homepage": "https://github.com/your-org/betali#readme"
}